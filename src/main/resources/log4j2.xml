<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="INFO">
	<Properties>
	<!-- Windows Server 
  <Property name="logDir">logs</Property>
  -->
  
  <!-- Use absolute path for reliability in Linux -->
  <Property name="logDir">/opt/tomcat/logs</Property>
 
	</Properties>
	<Appenders>
		<Console name="console" target="SYSTEM_OUT">
			<PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] [%X{requestUuid}] %-5level %logger{36} (%F:%L) - %msg%n" />
		</Console>
		<RollingFile name="file"
			fileName="${logDir}/softwarerequest_api.log"
			filePattern="${logDir}/softwarerequest_api-%d{yyyy-MM-dd}-%i.log">
			<PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] [%X{requestUuid}] %-5level %logger{36} (%F:%L) - %msg%n" />
			<Policies>
				<TimeBasedTriggeringPolicy />
				<SizeBasedTriggeringPolicy size="5KB" />
			</Policies>
			<DefaultRolloverStrategy max="20" />
		</RollingFile>
	</Appenders>
	<Loggers>
		<Root level="debug">
			<AppenderRef ref="console" />
			<AppenderRef ref="file" />
		</Root>
	</Loggers>
</Configuration>